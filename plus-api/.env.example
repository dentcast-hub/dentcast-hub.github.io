# --- Database ---------------------------------------------------------------
# The API and the migration tool both read DATABASE_URL. In local dev this
# points at the Postgres container from docker-compose.yml.
DATABASE_URL=postgres://dentcast:dentcast@localhost:5432/dentcast_plus

# --- HTTP server ------------------------------------------------------------
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed browser origins (the static site).
# In dev the site is usually served from a file:// or a local http server.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080

# --- Sessions ---------------------------------------------------------------
# Secret used to sign the httpOnly session cookie. Change in production.
SESSION_SECRET=dev-insecure-change-me-in-production-000000000000000000000000
# Cookie flags. In production behind HTTPS set SESSION_COOKIE_SECURE=true.
SESSION_COOKIE_NAME=dcp_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30

# --- OTP --------------------------------------------------------------------
# In dev the code is printed to the server console (SMS_PROVIDER=console).
# Switch to a real Iranian provider at deploy without touching business logic.
SMS_PROVIDER=console
OTP_TTL_SECONDS=120
OTP_LENGTH=5
# Rate limits (per phone and per IP) for OTP requests.
OTP_MAX_PER_PHONE_PER_HOUR=5
OTP_MAX_PER_IP_PER_HOUR=15

# --- Notifications ----------------------------------------------------------
# Delivery channel behind the provider-agnostic send() interface:
#   stub     - dev: logs instead of delivering
#   webpush  - LIVE channel for the public release (browser / installed PWA)
#   telegram - messenger channel + OTP fallback (locked until the connection ships)
NOTIFY_PROVIDER=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Web Push (VAPID) -------------------------------------------------------
# Generate a keypair once:  npx web-push generate-vapid-keys
# The PUBLIC key is served to the browser at /push/public-key (safe to expose);
# the PRIVATE key must stay secret. With both empty (dev), the webpush provider
# logs instead of sending, so the whole flow still runs without secrets.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:foad.shahabian@gmail.com

# --- New-article notifications ----------------------------------------------
# Premium is pushed immediately on publish. Free is batched into one digest by a
# daily cron at ARTICLE_FREE_DIGEST_HOUR (local, Asia/Tehran) for articles whose
# notify_free_after (published_at + ARTICLE_FREE_DELAY_HOURS) has passed. The
# effective free delay is therefore 24-48h ("۱ تا ۲ روز").
ARTICLE_FREE_DELAY_HOURS=24
ARTICLE_FREE_DIGEST_HOUR=21

# --- Anonymous events -------------------------------------------------------
ANON_EVENT_MAX_PER_IP_PER_HOUR=60

# --- Admin (founder-only KPI page) ------------------------------------------
# HTTP Basic auth for the /admin KPI endpoints.
ADMIN_USER=founder
ADMIN_PASSWORD=change-me-admin-password

# --- Timezone ---------------------------------------------------------------
# Day boundary for streaks. Do not change; the spec fixes this to Asia/Tehran.
STREAK_TIMEZONE=Asia/Tehran

# --- Content taxonomy index -------------------------------------------------
# Path to plus/content-index.json (tools/build_plus_index.mjs output). Empty =
# resolve the repo's plus/ dir automatically (dev). Set explicitly in the
# container, where the API and the static site are deployed separately.
CONTENT_INDEX_PATH=
