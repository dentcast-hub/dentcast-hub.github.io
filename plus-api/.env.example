# --- Database ---------------------------------------------------------------
# The API and the migration tool both read DATABASE_URL. In local dev this
# points at the Postgres container from docker-compose.yml.
DATABASE_URL=postgres://dentcast:dentcast@localhost:5432/dentcast_plus

# --- HTTP server ------------------------------------------------------------
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed browser origins (the static site).
# In dev the site is usually served from a file:// or a local http server.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080

# --- Sessions ---------------------------------------------------------------
# Secret used to sign the httpOnly session cookie. Change in production.
SESSION_SECRET=dev-insecure-change-me-in-production-000000000000000000000000
# Cookie flags. In production behind HTTPS set SESSION_COOKIE_SECURE=true.
SESSION_COOKIE_NAME=dcp_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30

# --- OTP --------------------------------------------------------------------
# In dev the code is printed to the server console (SMS_PROVIDER=console).
# Switch to a real Iranian provider at deploy without touching business logic.
SMS_PROVIDER=console
OTP_TTL_SECONDS=120
OTP_LENGTH=5
# Rate limits (per phone and per IP) for OTP requests.
OTP_MAX_PER_PHONE_PER_HOUR=5
OTP_MAX_PER_IP_PER_HOUR=15

# --- Notifications ----------------------------------------------------------
# Telegram is the first notification provider; stubbed in dev.
NOTIFY_PROVIDER=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Anonymous events -------------------------------------------------------
ANON_EVENT_MAX_PER_IP_PER_HOUR=60

# --- Admin (founder-only KPI page) ------------------------------------------
# HTTP Basic auth for the /admin KPI endpoints.
ADMIN_USER=founder
ADMIN_PASSWORD=change-me-admin-password

# --- Timezone ---------------------------------------------------------------
# Day boundary for streaks. Do not change; the spec fixes this to Asia/Tehran.
STREAK_TIMEZONE=Asia/Tehran
